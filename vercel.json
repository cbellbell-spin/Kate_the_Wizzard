{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/analyze-v1", "dest": "/api/analyze-v1.js" },
    { "src": "/api/analyze-q2", "dest": "/api/analyze-q2.js" },
    { "src": "/api/analyze-final", "dest": "/api/analyze-final.js" }
  ]
}
